{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python app.py)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(pip install:*)",
      "Bash(pip freeze)",
      "Bash(pip list:*)",
      "Bash(flask:*)",
      "Bash(sqlite3 expense_tracker.db:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(tree:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Read(./.env)",
      "Read(./expense_tracker.db)"
    ]
  }
}
